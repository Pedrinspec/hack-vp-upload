# =============================================================================
# VP-UPLOAD — Variáveis de Ambiente
# Copie este arquivo para infra/.env e preencha os valores
# NUNCA commite o arquivo .env com credenciais reais
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados MySQL
# -----------------------------------------------------------------------------
DATABASE_USER=vpuser
DATABASE_PASSWORD=root

# -----------------------------------------------------------------------------
# AWS S3 — OBRIGATÓRIO (sem valores padrão)
# -----------------------------------------------------------------------------
AWS_REGION=sa-east-1
ACCESS_KEY=
ACCESS_SECRET=
AWS_SESSION_TOKEN=
S3_VIDEO_BUCKET=hack-vp-videos

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
VIDEO_PROCESSOR_TOPIC=video-processor-topic
VIDEO_NOTIFICATION_TOPIC=video.failed.v1
VIDEO_UPLOAD_TOPIC=video.upload.status.v1
VIDEO_UPLOAD_GROUP_ID=video-upload
AUTO_OFFSET_RESET_CONFIG=earliest

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TIMEOUT=60000